{
  "name": "Toolkit-for-VIEW-2",
  "version": "1.0.1.74",
  "description": "My Chrome Extension",
  "private": true,
  "webExt": {
    "sourceDir": "dist"
  },
  "scripts": {
    "watch": "webpack --mode=development --watch --config config/webpack.config.js",
    "build": "webpack --mode=production --config config/webpack.config.js",
    "upload": "export $(grep -v '^#' .env | xargs) && npx chrome-webstore-upload upload",
    "upload:publish": "export $(grep -v '^#' .env | xargs) && npx chrome-webstore-upload",
    "test": "jest",
    "bump": "node scripts/bump-version.js",
    "deploy": "npm run bump && npm run build && npm run upload:publish"
  },
