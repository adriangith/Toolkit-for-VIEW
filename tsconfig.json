{
    "compilerOptions": {
        "target": "es2017",
        "module": "nodenext",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "sourceMap": true,
        "jsx": "react"
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.tsx",
        "src/__tests__/jest.test.js"
    ],
    "exclude": [
        "node_modules"
    ]
}